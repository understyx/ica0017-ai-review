<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cloud Technologies Study App</title>
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>Cloud Technologies Study Packs</h1>
            <p>Generated study materials including notes, flashcards, and quizzes.</p>
        </header>

        <main>
            <h2>Available Modules</h2>
            <% if (lectures && lectures.length > 0) { %>
                <ul class="lecture-list">
                <% lectures.forEach(function(lecture) { %>
                    <li>
                        <a href="/lecture/<%= lecture %>" class="lecture-link">
                            <span class="lecture-title"><%= lecture.charAt(0).toUpperCase() + lecture.slice(1) %> Study Pack</span>
                        </a>
                    </li>
                <% }); %>
                </ul>
            <% } else { %>
                <p>No study packs available at the moment.</p>
            <% } %>
        </main>
    </div>
</body>
</html>
